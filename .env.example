# Copy to .env and set values. Do not commit .env.

# Database (local development)
DATABASE_URL=postgresql://qbms:qbms@localhost:5432/qbms
REDIS_URL=redis://localhost:6379

# Auth (use strong secrets in production)
JWT_SECRET=change-me-in-production-use-strong-random-string
REFRESH_SECRET=change-me-in-production-use-different-strong-random-string

# API Configuration
PORT=4000
NODE_ENV=development

# CORS (for local development, use http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000

# Upload directory (fallback if Azure not configured)
UPLOAD_DIR=./uploads

# Azure Blob Storage Configuration (optional)
AZURE_ACCOUNT_NAME=your-storage-account-name
AZURE_ACCOUNT_KEY=your-storage-account-key
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=qbms

# OpenAI – required for AI question generation (Dashboard → Questions → Generate with AI)
OPENAI_API_KEY=

# Optional: override model (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# SMTP Email Configuration (for password reset and OTP verification)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@qbms.local

# Application URL (for email links)
APP_URL=http://localhost:8080
